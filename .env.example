# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_APP=src.main:create_app

# Cassandra Configuration (Personas)
CASSANDRA_HOSTS=127.0.0.1
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=persona
CASSANDRA_USERNAME=         # Dejar vacío si no tiene autenticación
CASSANDRA_PASSWORD=         # Dejar vacío si no tiene autenticación

# MongoDB Configuration (Productos)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=productos

# MySQL Configuration (Facturas)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=ventas

# Neo4j Configuration (Recomendaciones)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123
NEO4J_DATABASE=19mayo

# Application Settings
SECRET_KEY=your-secret-key-here
